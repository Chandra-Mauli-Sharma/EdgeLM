<!-- EdgeLM splash mark — matches the official Goo Drip icon exactly:
     matcha-gradient body, gloss highlight, single eye. Inset via a larger
     viewport so it sits inside the circular splash mask on Android 12+. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="288dp"
    android:height="288dp"
    android:viewportWidth="720"
    android:viewportHeight="720">
    <!-- Larger viewport => more padding, so the mark stays fully inside the
         circular splash mask (no clipped shoulders). Centered: ghost bbox center
         (256,266) mapped to viewport center (360,360). -->
    <group
        android:translateX="104"
        android:translateY="94">

        <!-- body: matcha gradient (lime -> green -> cyan) -->
        <path android:pathData="M256,80 C356,80 432,150 432,244 C432,300 404,340 404,372 C404,404 380,432 352,432 C330,432 320,414 300,414 C280,414 276,452 256,452 C236,452 232,414 212,414 C192,414 182,432 160,432 C132,432 108,404 108,372 C108,340 80,300 80,244 C80,150 156,80 256,80 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="80" android:startY="80"
                    android:endX="440" android:endY="470">
                    <item android:offset="0" android:color="#FFD4FF6E" />
                    <item android:offset="0.6" android:color="#FF7CEB1E" />
                    <item android:offset="1" android:color="#FF2DE3FF" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- gloss highlight (soft white) -->
        <path android:pathData="M92,176 a104,60 0 1,0 208,0 a104,60 0 1,0 -208,0 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="radial"
                    android:centerX="165" android:centerY="150"
                    android:gradientRadius="120">
                    <item android:offset="0" android:color="#80FFFFFF" />
                    <item android:offset="1" android:color="#00FFFFFF" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- single eye -->
        <path
            android:fillColor="#0B0E10"
            android:pathData="M308,250 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0 Z" />
    </group>
</vector>
