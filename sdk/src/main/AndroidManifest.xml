<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      The SDK needs to see and bind the runtime-service package.
      Android 11+ package visibility: declare the runtime component explicitly.
    -->
    <queries>
        <package android:name="ai.edgelm.runtime" />
    </queries>

    <!--
      The runtime gates its service behind this permission. Declaring it here means
      every app that includes the EdgeLM SDK inherits it via manifest merge — the
      developer doesn't have to add anything, and the app can bind the runtime.
      (Defined by the runtime app with protectionLevel="normal", granted at install.)
    -->
    <uses-permission android:name="ai.edgelm.permission.USE_RUNTIME" />
</manifest>

